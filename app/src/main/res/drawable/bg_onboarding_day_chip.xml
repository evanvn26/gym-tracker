<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/onboarding_accent_soft" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="@color/onboarding_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/onboarding_surface" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="@color/onboarding_border" />
        </shape>
    </item>
</selector>
