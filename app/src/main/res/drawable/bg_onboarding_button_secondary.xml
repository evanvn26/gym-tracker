<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/onboarding_surface_alt" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="@color/onboarding_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/onboarding_surface" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="@color/onboarding_border" />
        </shape>
    </item>
</selector>
