<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_onboarding_panel"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_complete_title"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/onboarding_complete_body"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/completeTargetsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:padding="18dp"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/completeBlockedAppsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:padding="18dp"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/completeLocationSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:padding="18dp"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />
    </LinearLayout>

</ScrollView>
