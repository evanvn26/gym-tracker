<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_onboarding_panel"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_complete_title"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/onboarding_complete_body"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/completeTargetsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:padding="14dp"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/completeBlockedAppsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:padding="14dp"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/completeLocationSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:padding="14dp"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />
    </LinearLayout>

</ScrollView>
