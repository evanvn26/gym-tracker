<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/onboardingBlockedAppRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_onboarding_surface"
    android:gravity="center_vertical"
    android:minHeight="90dp"
    android:orientation="horizontal"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/onboardingBlockedAppNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/onboardingBlockedAppCheck"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/bg_onboarding_check_indicator"
        android:button="@null"
        android:gravity="center"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="✓"
        android:textColor="@color/onboarding_check_indicator_text"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
