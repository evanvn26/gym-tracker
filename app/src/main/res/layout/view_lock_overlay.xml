<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC101828"
    android:clickable="true"
    android:focusable="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_onboarding_panel"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/lockTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lock_overlay_title"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lockReasonText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lockedPackageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/unlockTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
