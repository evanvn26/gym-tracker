<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_onboarding_panel"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_location_title"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/onboarding_location_body"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_location_latitude_label"
                android:textColor="@color/onboarding_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/locationLatitudeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_onboarding_input"
                android:hint="@string/onboarding_location_input_latitude_hint"
                android:inputType="numberSigned|numberDecimal"
                android:padding="16dp"
                android:textColor="@color/onboarding_text_primary"
                android:textColorHint="@color/onboarding_text_tertiary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/onboarding_location_longitude_label"
                android:textColor="@color/onboarding_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/locationLongitudeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_onboarding_input"
                android:hint="@string/onboarding_location_input_longitude_hint"
                android:inputType="numberSigned|numberDecimal"
                android:padding="16dp"
                android:textColor="@color/onboarding_text_primary"
                android:textColorHint="@color/onboarding_text_tertiary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/locationStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/onboarding_location_helper"
                android:textColor="@color/onboarding_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/locationSelectedLabelText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_onboarding_surface_selected"
            android:padding="18dp"
            android:text="@string/onboarding_location_selected_label"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

</ScrollView>
