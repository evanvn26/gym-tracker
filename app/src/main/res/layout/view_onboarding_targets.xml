<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_onboarding_panel"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_targets_title"
            android:textColor="@color/onboarding_text_primary"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/onboarding_targets_schedule_label"
            android:textColor="@color/onboarding_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <CheckBox
                android:id="@+id/targetDayMondayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_monday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/targetDayTuesdayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_tuesday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/targetDayWednesdayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_wednesday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/targetDayThursdayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_thursday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/targetDayFridayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_friday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/targetDaySaturdayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_saturday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/targetDaySundayCheck"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_onboarding_day_chip"
                android:button="@null"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/day_sunday"
                android:textColor="@color/onboarding_day_chip_text"
                android:textSize="16sp"
                android:textStyle="bold" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_onboarding_surface_alt"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_targets_duration_label"
                android:textColor="@color/onboarding_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/targetsDurationValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/onboarding_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sessionHoursSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:max="7"
                android:progress="1"
                android:progressBackgroundTint="@color/onboarding_progress_track"
                android:progressTint="@color/onboarding_accent"
                android:splitTrack="false"
                android:thumbTint="@color/onboarding_accent" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
